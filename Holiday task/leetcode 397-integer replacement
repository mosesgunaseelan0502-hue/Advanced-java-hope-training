class Solution {
    public int integerReplacement(int n) {
        int c=0;
        long n1=n;
        while(n1!=1){
        if(n1%2==0){
             n1=n1/2;
             c++;
        }
        else if(n1<4){
            n1-=1;
            c++;
        }
        else{
           
            if(n1%4==1){
                 n1-=1;
                 c++;
        }
         else {
                n1+=1;
                c++;
            }
        }
    }
    return c;
    }
}
