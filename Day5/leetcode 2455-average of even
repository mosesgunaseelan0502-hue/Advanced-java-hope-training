class Solution {
    public int averageValue(int[] nums) {
        int c=0;
        int sum=0;
        for(int i=0;i<nums.length;i++){
            if(nums[i]%6==0){
                c++;
                sum+=nums[i];
            }


        }
        if(sum==0) return 0;
        return sum/c;
        
    }
}
